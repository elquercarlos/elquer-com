---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const authorURL = new URL("/sobre/", Astro.site).toString();
const logoURL = new URL("/favicon.svg", Astro.site).toString();

const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		"headline": title,
		"description": description,
		"datePublished": pubDate.toISOString(),
		"dateModified": (updatedDate ?? pubDate).toISOString(),
		"author": {
			"@type": "Person",
			"name": "Elquer Carlos",
			"url": authorURL,
		},
		"publisher": {
			"@type": "Organization",
			"name": "Elquer Carlos",
			"logo": {
				"@type": "ImageObject",
				"url": logoURL,
			},
		},
		"mainEntityOfPage": canonicalURL.toString(),
	},
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"name": "Home",
				"item": new URL("/", Astro.site).toString(),
			},
			{
				"@type": "ListItem",
				"position": 2,
				"name": "Devlog",
				"item": new URL("/blog/", Astro.site).toString(),
			},
			{
				"@type": "ListItem",
				"position": 3,
				"name": title,
				"item": canonicalURL.toString(),
			},
		],
	},
];
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead
			title={`${title} — Elquer Carlos`}
			description={description}
			image={heroImage}
			type="article"
			article={{
				publishedTime: pubDate.toISOString(),
				modifiedTime: (updatedDate ?? pubDate).toISOString(),
				author: "Elquer Carlos",
			}}
			jsonLd={jsonLd}
		/>
	</head>
	<body>
		<Header />

		<main>
			<article>
				<header class="post-header">
					<div class="container">
						<p class="post-date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated"> · atualizado em <FormattedDate date={updatedDate} /></span>
							)}
						</p>
						<h1>{title}</h1>
						{description && <p class="post-description">{description}</p>}
					</div>
				</header>

				<div class="container">
					<div class="prose">
						<slot />
					</div>
					<div class="fim-do-ato">Fim do ato</div>
				</div>
			</article>
		</main>

		<Footer />

		<style>
			.post-header {
				padding: var(--space-16) 0 var(--space-12);
				text-align: center;
			}

			.post-header h1 {
				font-size: clamp(2rem, 5vw, 3rem);
				max-width: 720px;
				margin: 0 auto var(--space-4);
				line-height: 1.15;
			}

			.post-date {
				font-family: var(--font-mono);
				font-size: var(--text-xs);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: var(--space-4);
			}

			.updated {
				color: var(--text);
				opacity: 0.5;
			}

			.post-description {
				font-family: var(--font-display);
				font-style: italic;
				font-size: var(--text-xl);
				color: var(--text);
				opacity: 0.75;
				max-width: 600px;
				margin: 0 auto;
				font-variation-settings: "opsz" 24;
			}

			.prose {
				max-width: 680px;
				margin: 0 auto;
				padding-top: var(--space-8);
			}

			.prose :global(h2) {
				font-size: var(--text-2xl);
				margin-top: var(--space-12);
			}

			.prose :global(h3) {
				font-size: var(--text-xl);
				margin-top: var(--space-8);
			}

			.prose :global(p) {
				margin-bottom: var(--space-4);
			}

			.prose :global(ul),
			.prose :global(ol) {
				margin: var(--space-4) 0;
				padding-left: var(--space-6);
			}

			.prose :global(li) {
				margin-bottom: var(--space-2);
			}
		</style>
	</body>
</html>