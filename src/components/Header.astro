---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
---

<header>
	<div class="container-wide header-inner">
		<a href="/" class="brand">{SITE_TITLE}</a>
		<nav>
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Devlog</HeaderLink>
			<HeaderLink href="/projetos">Projetos</HeaderLink>
			<HeaderLink href="/sobre">Sobre</HeaderLink>
			<HeaderLink href="/contato">Contato</HeaderLink>
		</nav>
	</div>
</header>

<style>
	header {
		background: var(--palco);
		border-bottom: 1px solid var(--divider-on-dark);
		padding: var(--space-4) 0;
	}

	.header-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.brand {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: var(--text-xl);
		color: var(--tinta-clara);
		border-bottom: none;
		letter-spacing: -0.01em;
	}

	.brand:hover {
		color: var(--accent);
		border-bottom: none;
	}

	nav {
		display: flex;
		gap: var(--space-6);
	}

	@media (max-width: 720px) {
		.header-inner {
			flex-direction: column;
			gap: var(--space-4);
		}
		nav {
			gap: var(--space-4);
			flex-wrap: wrap;
			justify-content: center;
		}
	}
</style>