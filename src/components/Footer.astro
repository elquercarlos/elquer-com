---
import CookieBanner from "./CookieBanner.astro";

const today = new Date();
---

<footer>
	<div class="container-wide footer-inner">
		<p class="copy">&copy; {today.getFullYear()} Elquer Carlos</p>
		<nav class="social">
			<a href="https://youtube.com/@ElquerCarlos_ia" target="_blank" rel="noopener">YouTube</a>
			<a href="https://github.com/elquercarlos" target="_blank" rel="noopener">GitHub</a>
			<a href="https://linkedin.com/in/elquercarlos" target="_blank" rel="noopener">LinkedIn</a>
			<button type="button" class="cookie-link" id="footer-cookie-link">Cookies</button>
		</nav>
	</div>
</footer>

<CookieBanner />

<script is:inline>
	(function () {
		var link = document.getElementById("footer-cookie-link");
		if (!link) return;
		link.addEventListener("click", function () {
			if (typeof window.elquerOpenCookieBanner === "function") {
				window.elquerOpenCookieBanner();
			}
		});
	})();
</script>

<style>
	footer {
		background: var(--palco);
		color: var(--tinta-clara);
		padding: var(--space-12) 0 var(--space-8);
		margin-top: var(--space-24);
		border-top: 1px solid var(--divider-on-dark);
	}

	.footer-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-6);
	}

	.copy {
		font-size: var(--text-sm);
		opacity: 0.6;
		margin: 0;
	}

	.social {
		display: flex;
		gap: var(--space-6);
	}

	.social a {
		color: var(--tinta-clara);
		font-size: var(--text-sm);
		opacity: 0.75;
		border-bottom: 1px solid transparent;
		padding-bottom: 2px;
	}

	.social a:hover {
		opacity: 1;
		border-bottom-color: var(--accent);
	}

	.cookie-link {
		background: transparent;
		border: none;
		padding: 0 0 2px 0;
		color: var(--tinta-clara);
		font-size: var(--text-sm);
		font-family: inherit;
		opacity: 0.75;
		cursor: pointer;
		border-bottom: 1px solid transparent;
	}

	.cookie-link:hover {
		opacity: 1;
		border-bottom-color: var(--accent);
	}

	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			gap: var(--space-4);
			text-align: center;
		}
	}
</style>